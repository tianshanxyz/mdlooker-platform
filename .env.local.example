# ============================================
# MDLooker Platform 环境变量配置模板
# 复制此文件为 .env.local 并填入实际值
# ============================================

# ============================================
# 1. Supabase 配置（必需）
# ============================================

# Supabase 项目 URL
# 获取方式：Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（客户端使用）
# 获取方式：Supabase Dashboard → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 服务角色密钥（服务端使用，用于数据导入）
# 获取方式：Supabase Dashboard → Project Settings → API → Project API keys → service_role secret
# ⚠️ 警告：此密钥具有完全数据库访问权限，请勿泄露！
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# 2. 应用配置（可选）
# ============================================

# 应用基础 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 调试模式
# true = 所有用户拥有 VIP 权限（开发环境使用）
# false = 正常权限控制（生产环境使用）
NEXT_PUBLIC_DEBUG_MODE=false

# ============================================
# 3. 第三方 API 配置（可选）
# ============================================

# FDA API 密钥（用于数据采集）
# 获取方式：https://open.fda.gov/apis/authentication/
FDA_API_KEY=your-fda-api-key

# 百度翻译 API（用于多语言功能）
# 获取方式：https://fanyi-api.baidu.com/
BAIDU_TRANSLATE_APP_ID=your-baidu-app-id
BAIDU_TRANSLATE_SECRET_KEY=your-baidu-secret-key

# ============================================
# 4. SEO/GEO 监控配置（可选）
# ============================================

# Google Analytics
NEXT_PUBLIC_GA_ENABLED=false
NEXT_PUBLIC_GA_PROPERTY_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
NEXT_PUBLIC_SEARCH_CONSOLE_ENABLED=false
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Ahrefs API（用于 SEO 监控）
AHREFS_API_KEY=your-ahrefs-api-key
AHREFS_API_ENABLED=false

# SEMrush API（用于 SEO 监控）
SEMRUSH_API_KEY=your-semrush-api-key
SEMRUSH_API_ENABLED=false

# ============================================
# 5. 安全配置（生产环境必需）
# ============================================

# JWT 密钥（用于用户认证）
JWT_SECRET=your-jwt-secret-key-min-32-characters-long

# 加密密钥（用于敏感数据加密）
ENCRYPTION_KEY=your-encryption-key-min-32-characters

# ============================================
# 配置说明
# ============================================

# 开发环境最小配置：
# 1. NEXT_PUBLIC_SUPABASE_URL
# 2. NEXT_PUBLIC_SUPABASE_ANON_KEY
# 3. SUPABASE_SERVICE_ROLE_KEY（用于数据导入）

# 生产环境建议配置：
# 1. 所有 Supabase 配置
# 2. JWT_SECRET 和 ENCRYPTION_KEY
# 3. 必要的第三方 API 密钥
# 4. SEO/GEO 监控配置

# 注意事项：
# 1. 此文件包含敏感信息，请勿提交到 Git！
# 2. 已添加到 .gitignore，不会被提交
# 3. 生产环境使用强密码和密钥
# 4. 定期轮换密钥以提高安全性
